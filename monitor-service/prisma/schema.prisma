generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Monitor {
  id            Int       @id @default(autoincrement())
  url           String
  status        String    @default("UNKNOWN")
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
}